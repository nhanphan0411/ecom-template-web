    },
    {
      "page": "/api/admin/images/sync",
      "regex": "^/api/admin/images/sync(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/images/sync(?:/)?$"
    },
    {
      "page": "/api/admin/products",
      "regex": "^/api/admin/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/products(?:/)?$"
    },
    {
      "page": "/api/admin/value1",
      "regex": "^/api/admin/value1(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/value1(?:/)?$"
    },
    {
      "page": "/api/admin/value2",
      "regex": "^/api/admin/value2(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/value2(?:/)?$"
    },
    {
      "page": "/api/cart",
      "regex": "^/api/cart(?:/)?$",
      "routeKeys": {},
